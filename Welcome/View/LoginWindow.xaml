<Window x:Class="Welcome.View.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Welcome.View"
        mc:Ignorable="d"
            Title="Вход в системата" Height="250" Width="400">

    <StackPanel Margin="20">

        <!-- Потребителско име -->
        <StackPanel Orientation="Horizontal" Margin="0,10,0,5">
            <Label Content="Потребителско име:" Width="150"/>
            <TextBox x:Name="textBoxUserName" Width="180"/>
        </StackPanel>

        <!-- Парола -->
        <StackPanel Orientation="Horizontal" Margin="0,5,0,5">
            <Label Content="Парола:" Width="150"/>
            <TextBox x:Name="textBoxPassword" Width="180"/>
        </StackPanel>

        <!-- Грешка -->
        <TextBlock x:Name="textBlockError" Foreground="Red" 
                   Margin="0,5,0,5" TextWrapping="Wrap"/>

        <!-- Бутон -->
        <Button x:Name="button" Content="Вход (Login)" 
                Width="100" Margin="0,10,0,0"
                Click="button_Click"/>

    </StackPanel>
</Window>
